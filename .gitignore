# Go project .gitignore

# Build and test artifacts
/bin/
/pkg/
/coverage/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Go modules
vendor/

# Coverage files
coverage.out
coverage.html
coverage

# Temporary files
tmp/
temp/

# Log files
logs/
*.log

# Backup files
*.bak
*.backup

# Windows files
Thumbs.db
ehthumbs.db

# macOS files
.DS_Store
.AppleDouble
.LSOverride

# Linux files
*~

# Editor directories and files
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.gitattributes
.editorconfig
